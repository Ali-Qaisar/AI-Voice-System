# ============================================================
# Friday AI Configuration - Online Models Edition
# ============================================================
# Copy this file to .env and configure your settings

# ============================================================
# 🎤 SPEECH SETTINGS (Online Services)
# ============================================================

# Speech-to-Text Engine
# Options:
#   - google_free: Google Web Speech API (free, default, ~50 requests/day)
#   - google: Google Cloud Speech-to-Text (paid, requires credentials)
#   - whisper_api: OpenAI Whisper API (paid, requires OPENAI_API_KEY)
SPEECH_ENGINE=google_free

# Text-to-Speech Engine
# Options:
#   - gtts: Google Text-to-Speech (free, default, unlimited with rate limits)
#   - google_cloud: Google Cloud TTS (paid, requires credentials)
#   - elevenlabs: ElevenLabs API (paid, premium quality, requires ELEVENLABS_API_KEY)
TTS_ENGINE=gtts

# ============================================================
# 🧠 BRAIN SETTINGS (Online AI Models)
# ============================================================

# LLM Provider
# Options:
#   - gemini: Google Gemini (free tier available, 60 req/min)
#   - openai: OpenAI GPT models (paid)
#   - anthropic: Anthropic Claude models (paid)
LLM_PROVIDER=gemini

# LLM Model Name
# For Gemini: gemini-flash-latest, gemini-pro-latest, gemini-2.5-flash
# For OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo
# For Anthropic: claude-3-5-sonnet-20241022, claude-3-opus-20240229
LLM_MODEL=gemini-flash-latest

# ============================================================
# 🔑 API KEYS
# ============================================================

# --- REQUIRED FOR DEFAULT SETUP ---
# Get a free Gemini API key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=AIzaSyDZnfQgTTs6U4lM3dEiWHvEhEKei7l24wI

# --- OPTIONAL: PREMIUM SERVICES ---

# OpenAI API Key (for GPT models or Whisper API)
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (for Claude models)
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Cloud Credentials (for premium Google Cloud services)
# Path to your service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\your\google-cloud-key.json

# ElevenLabs API Key (for premium text-to-speech)
# Get from: https://elevenlabs.io/
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Weather API Key (for weather skill)
# Get from: https://openweathermap.org/api
# WEATHER_API_KEY=your_openweathermap_key_here

# ============================================================
# 🛠️ SYSTEM SETTINGS
# ============================================================

# Wake word to activate the assistant
WAKE_WORD=friday

# ============================================================
# 💡 QUICK START GUIDE
# ============================================================
# 1. Copy this file to .env: copy .env.example .env
# 2. Get a free Gemini API key: https://makersuite.google.com/app/apikey
# 3. Replace "your_gemini_api_key_here" with your actual key
# 4. Run: python main.py
# 5. Say "Friday" to activate, then speak your command
#
# For more help, see: QUICK_START.md
# ============================================================
